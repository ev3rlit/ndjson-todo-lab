LB_PORT=8080
TODO_DATA_DIR=/srv/ndjson-todo/data
TODO_LOG_DIR=/srv/ndjson-todo/logs
NGINX_LOG_DIR=/srv/ndjson-todo/logs/nginx

NFS_SERVER_HOST=con2
NFS_EXPORT_ROOT=/srv/nfs/ndjson-todo
NFS_MOUNT_DIR=/mnt/ndjson-todo-nfs
NFS_MOUNT_OPTIONS=defaults,_netdev,nofail,vers=4.2

BACKUP_TARGET_DIR=/mnt/ndjson-todo-nfs/backups
BACKUP_CRON_SCHEDULE=*/5 * * * *
BACKUP_LOG_FILE=/var/log/ndjson-todo-backup.log
